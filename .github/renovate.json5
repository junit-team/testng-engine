{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>junit-team/renovate-config',
  ],
  platformAutomerge: true,
  packageRules: [
    {
      allowedVersions: '(,5.8)',
      description: [
        'Stick to 5.7.x as required baseline for JUnit',
      ],
      matchPackageNames: [
        'org.junit:{/,}**'
      ]
    },
    {
      "matchPackageNames": [
        "com.gradleup.nmcp:*",
      ],
      "allowedVersions": "<1.6.0", // due to https://github.com/GradleUp/nmcp/issues/262
    },
  ],
}
